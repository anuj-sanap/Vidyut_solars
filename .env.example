PORT=3000
ALLOWED_ORIGINS=https://vidyutsolar.in
JWT_SECRET=replace-with-long-random-token-secret
OWNER_PANEL_KEY=replace-with-owner-secret
ADMIN_EMAIL=admin@vidyutsolar.in
ADMIN_PASSWORD=replace-with-admin-password

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vidyut_solar?retryWrites=true&w=majority

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
ALERT_FROM_EMAIL=your-gmail@gmail.com
